@page "/"
@using HanumanQuest.Game
@implements IAsyncDisposable

<PageTitle>Hanuman's Leap</PageTitle>

<div class="game-shell">
    <canvas id="gameCanvas"></canvas>

    @if (_showIntro)
    {
        <div class="overlay" @onclick="StartGame">
            <div class="overlay__card">
                <div class="overlay__emoji">🐒🐘🦚</div>
                <h1>Hanuman's Leap</h1>
                <p>Three shadow-creatures are loose in the clearing. You can't fight them —
                fighting only makes them bigger. Walk up close, stand <strong>still</strong>,
                and <strong>watch</strong>. That's the only power that works.</p>
                <div class="overlay__keys">
                    <span><b>WASD</b> / arrows — move</span>
                    <span><b>Mouse</b> — look around</span>
                    <span><b>SPACE</b> — watch (hold still!)</span>
                </div>
                <button class="overlay__btn" type="button">Click to Begin ✨</button>
            </div>
        </div>
    }

    @if (_won)
    {
        <div class="overlay">
            <div class="overlay__card">
                <div class="overlay__emoji">🌙✨</div>
                <h1>All three have settled</h1>
                <p>Chanchal, Bhaari and Shaan aren't gone — they never are. You just showed them
                they didn't need to grab, hide or shout to be seen. That's the whole trick.</p>
                <a class="overlay__btn" href="../../practice/" target="_top">Try It For Real →</a>
            </div>
        </div>
    }
</div>

@code {
    private RayGame _game = new();
    private bool _showIntro = true;
    private bool _started;
    private bool _won;
    private bool _disposed;
    private const int Width = 480;
    private const int Height = 300;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Interop.LoadAsync();
        Interop.Init("gameCanvas", Width, Height);
        _ = RunLoopAsync();
    }

    private void StartGame()
    {
        _showIntro = false;
        _started = true;
    }

    private async Task RunLoopAsync()
    {
        var last = DateTime.UtcNow;
        while (!_disposed)
        {
            await Task.Delay(33);
            var now = DateTime.UtcNow;
            var dt = Math.Min(0.1, (now - last).TotalSeconds);
            last = now;

            if (!_started) continue;

            var input = Interop.GetInput();
            _game.Update(dt, input[0], input[1], input[2], input[3], input[4], input[5] > 0.5);

            RenderFrame();

            if (_game.Won && !_won)
            {
                _won = true;
                StateHasChanged();
            }
        }
    }

    private void RenderFrame()
    {
        var wallData = new double[Width * 2];
        const double fov = 66.0 * Math.PI / 180.0;
        for (var col = 0; col < Width; col++)
        {
            var rayAngle = _game.PlayerAngle - fov / 2 + fov * col / Width;
            var (dist, type) = _game.CastRay(rayAngle);
            wallData[col * 2] = dist;
            wallData[col * 2 + 1] = type;
        }

        var visible = new List<double>();
        foreach (var c in _game.Creatures)
        {
            if (c.Calmed) continue;
            var dx = c.X - _game.PlayerX;
            var dy = c.Y - _game.PlayerY;
            var dist = Math.Sqrt(dx * dx + dy * dy);
            var angleTo = Math.Atan2(dy, dx);
            var rel = angleTo - _game.PlayerAngle;
            while (rel > Math.PI) rel -= 2 * Math.PI;
            while (rel < -Math.PI) rel += 2 * Math.PI;
            if (Math.Abs(rel) > fov * 0.75) continue;

            var screenXFrac = 0.5 + rel / fov;
            visible.Add(screenXFrac);
            visible.Add(dist);
            visible.Add(c.TypeCode);
            visible.Add(c.CalmProgress);
        }

        var hud = $"Settled: {_game.CalmedCount} / {_game.Creatures.Count}   ·   Hold SPACE and stand still near a creature to watch it";
        Interop.Render(wallData, visible.ToArray(), hud, _game.Toast ?? string.Empty, _game.Won);
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        return ValueTask.CompletedTask;
    }
}
